                        <div class="input-item"><input type="text" id="regAccount" placeholder="设置账号"></div>
                        <div class="input-item"><input type="email" id="regEmail" placeholder="邮箱（可选）"></div>
                        <div class="input-item"><input type="tel" id="regPhone" placeholder="手机号（可选）"></div>
                        <div class="input-item"><input type="password" id="regPwd" placeholder="设置密码"></div>
                        <button class="btn" onclick="register()" style="width:100%">注册并登录</button>
                        <div class="link" style="margin-top:8px;"><span onclick="switchToLogin()">返回登录</span></div>
                    </div>
                    <div class="login-sub-panel" id="forgetSubPanel" style="display:none;">
                        <div class="input-item"><input type="text" id="forgetAccount" placeholder="账号/邮箱/手机号"></div>
                        <div class="input-item"><input type="password" id="newPwd" placeholder="新密码"></div>
                        <button class="btn" onclick="findPwd()" style="width:100%">重置密码</button>
                        <div class="link" style="margin-top:8px;"><span onclick="switchToLogin()">返回登录</span></div>
