                <div class="setting-tab-btn active" onclick="switchSettingTab(1)">用户信息</div>
                <div class="setting-tab-btn" onclick="switchSettingTab(2)">回复设置</div>
                <div class="setting-tab-btn" onclick="switchSettingTab(3)">主题背景</div>
                <div class="setting-tab-btn" onclick="switchSettingTab(4)">存储管理</div>
            </div>
            <div class="setting-panel active" id="panel1">
                <div id="userInfoPanel" style="display:none;">
                    <div class="input-item"><label>用户昵称：</label><input type="text" id="setName" placeholder="修改昵称"></div>
