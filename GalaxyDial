        // 字卡生成并记录使用次数
        function generateSmartSentence(userMsg) {
            let allCards = [...defaultCards, ...chatData.userCards]; if (allCards.length === 0) return '嗯嗯。';
            let msg = userMsg.toLowerCase();

            function pickAndCount(candidates) {
                if (candidates.length === 0) return null;
                let selected = candidates[Math.floor(Math.random() * candidates.length)];
                chatData.cardUse[selected] = (chatData.cardUse[selected] || 0) + 1;
                return selected;
            }

            let g = allCards.filter(c => c.includes('好') || c.includes('在吗'));
            if (g.length) { let s = pickAndCount(g); if (s) return s; }
            let c = allCards.filter(c => c.includes('休息') || c.includes('照顾') || c.includes('吃饭'));
            if (c.length) { let s = pickAndCount(c); if (s) return s; }
            let l = allCards.filter(c => c.includes('想') || c.includes('爱'));
            if (l.length) { let s = pickAndCount(l); if (s) return s; }
            let s = allCards.filter(c => c.includes('连接') || c.includes('信号'));
            if (s.length) { let s2 = pickAndCount(s); if (s2) return s2; }
            let w = allCards.filter(c => c.includes('天气') || c.includes('雨') || c.includes('冷') || c.includes('热'));
            if (w.length) { let s2 = pickAndCount(w); if (s2) return s2; }
            let p = allCards.filter(c => c.includes('生理期') || c.includes('红糖') || c.includes('疼') || c.includes('保暖'));
            if (p.length) { let s2 = pickAndCount(p); if (s2) return s2; }

            let selected = allCards[Math.floor(Math.random() * allCards.length)];
            chatData.cardUse[selected] = (chatData.cardUse[selected] || 0) + 1;
            return selected;
        }

