        // 梦角回信相关
        function getMultipleSmartSentences(originalContent, count = 3) {
            let all = [...defaultCards, ...chatData.userCards];
            if (all.length === 0) return ['嗯嗯。'];
            let msg = originalContent.toLowerCase();
            let candidates = all.filter(c => {
                let low = c.toLowerCase();
                return (msg.includes('好') && low.includes('好')) ||
                       (msg.includes('累') && (low.includes('累') || low.includes('休息'))) ||
                       (msg.includes('想你') && low.includes('想')) ||
                       (msg.includes('爱') && low.includes('爱')) ||
                       (msg.includes('天气') && (low.includes('天气') || low.includes('雨') || low.includes('冷') || low.includes('热'))) ||
                       (msg.includes('生理期') && (low.includes('生理期') || low.includes('红糖') || low.includes('疼') || low.includes('保暖')));
            });
            if (candidates.length === 0) candidates = all;
            let used = new Set();
            let res = [];
            for (let i = 0; i < count * 2 && res.length < count && candidates.length > 0; i++) {
                let idx = Math.floor(Math.random() * candidates.length);
                let s = candidates[idx];
                if (!used.has(s)) { used.add(s); res.push(s); }
            }
            while (res.length < count && all.length > 0) {
                let r = all[Math.floor(Math.random() * all.length)];
                if (!used.has(r)) { used.add(r); res.push(r); }
            }
            return res;
        }

        function autoReplyFromDreamRole(to, originalContent) {
            let coreSentences = getMultipleSmartSentences(originalContent, Math.floor(Math.random() * 3) + 2);
            let hasPrefix = Math.random() < 0.9;
            let hasSuffix = Math.random() < 0.9;
            let reply = '';
            if (hasPrefix) {
                let prefixCount = Math.floor(Math.random() * 2) + 1;
                for (let i = 0; i < prefixCount; i++) reply += moodPrefixes[Math.floor(Math.random() * moodPrefixes.length)] + ' ';
            }
            coreSentences.forEach((s, idx) => { reply += s; if (idx < coreSentences.length - 1) reply += '，'; else reply += '。'; });
            if (hasSuffix) {
                let suffixCount = Math.floor(Math.random() * 2) + 1;
                for (let i = 0; i < suffixCount; i++) reply += moodSuffixes[Math.floor(Math.random() * moodSuffixes.length)];
            }
            let time = new Date().toLocaleString();
            letterData.push({ type: 'reply', from: to, content: reply, time: time });
            saveLetterData();
            showNotification(`来自 ${to} 的回信`, () => { enterFeature('reply'); });
        }

        function replyAllUnrepliedLetters() {
            let sentLetters = letterData.filter(l => l.type === 'send');
