                chatData.userCards = [...new Set([...(chatData.userCards || []), ...userCards])];
                delete chatData.cards;
            }
            if (!chatData.userCards) chatData.userCards = [];
            chatData.contacts = chatData.contacts || ['宇宙助手'];
            if (!chatData.contactSettings) chatData.contactSettings = {};
            chatData.contacts.forEach(name => { if (!chatData.contactSettings[name]) chatData.contactSettings[name] = { avatar: 'https://via.placeholder.com/40', name: name }; });
            chatData.msgMap = chatData.msgMap || {};
            chatData.contacts.forEach(name => {
                if (!Array.isArray(chatData.msgMap[name])) chatData.msgMap[name] = [];
                chatData.msgMap[name] = chatData.msgMap[name].map((msg, idx) => {
                    if (!msg.id) msg.id = Date.now() + '-' + idx + '-' + Math.random();
                    if (msg.timestamp === undefined) msg.timestamp = Date.now() - 86400000;
                    return msg;
