        // 安全解析（兼容旧数据）
        function safeParse(json, defaultValue) {
            try { let parsed = JSON.parse(json); return deepMerge(defaultValue, parsed); } catch (e) { return defaultValue; }
        }
        function deepMerge(target, source) {
            if (typeof target !== 'object' || target === null || typeof source !== 'object' || source === null) return source !== undefined ? source : target;
            let result = Array.isArray(target) ? target.slice() : { ...target };
            for (let key in source) if (source.hasOwnProperty(key)) result[key] = deepMerge(target[key], source[key]);
            return result;
        }

