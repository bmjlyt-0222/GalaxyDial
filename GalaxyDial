                <div class="input-item"><label>回复频率（%）：</label><input type="number" id="replyRate" min="0" max="100" value="100"></div>
                <div class="input-item"><label>回复间隔（秒）：</label><input type="number" id="replyTime" min="1" value="3"><small>实际延迟增加随机缓冲</small></div>
                <div class="input-item"><label>主动发消息（秒）：</label><input type="number" id="autoSendTime" min="5" value="30"><small>0=关闭</small></div>
                <div class="input-item"><label><input type="checkbox" id="smartReplyCheck" checked> 启用智能回复</label></div>
                <div class="input-item"><label>词库搜索时间（秒）：</label><input type="number" id="searchTime" min="1" value="3"></div>
            </div>
            <div class="setting-panel" id="panel3">
                <div class="theme-box">
                    <h4>日夜模式</h4><div style="margin:10px 0;"><button class="btn small" onclick="switchMode('day')" id="dayModeBtn2">白天</button><button class="btn small" onclick="switchMode('night')" id="nightModeBtn2">夜晚</button></div>
