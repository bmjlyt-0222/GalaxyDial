            setTimeout(() => {
                let shuffled = [...tarotDeck];
                for (let i = shuffled.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
                }
                let selected = shuffled.slice(0, 3);
                let cardsWithOrientation = selected.map(c => ({
                    ...c,
                    isReversed: Math.random() < 0.3,
                }));
                cardsWithOrientation.forEach(c => c.displayName = c.name + (c.isReversed ? ' (逆位)' : ' (正位)'));

                document.getElementById('card1').innerHTML = `<h4>${cardsWithOrientation[0].displayName}</h4><div class="number">编号：${cardsWithOrientation[0].number}</div><div class="meaning">含义：${cardsWithOrientation[0].isReversed ? cardsWithOrientation[0].reversed.meaning : cardsWithOrientation[0].upright.meaning}</div><div class="message" style="margin-top:8px; font-style:italic;">传讯：${cardsWithOrientation[0].isReversed ? cardsWithOrientation[0].reversed.message : cardsWithOrientation[0].upright.message}</div>`;
                document.getElementById('card2').innerHTML = `<h4>${cardsWithOrientation[1].displayName}</h4><div class="number">编号：${cardsWithOrientation[1].number}</div><div class="meaning">含义：${cardsWithOrientation[1].isReversed ? cardsWithOrientation[1].reversed.meaning : cardsWithOrientation[1].upright.meaning}</div><div class="message" style="margin-top:8px; font-style:italic;">传讯：${cardsWithOrientation[1].isReversed ? cardsWithOrientation[1].reversed.message : cardsWithOrientation[1].upright.message}</div>`;
                document.getElementById('card3').innerHTML = `<h4>${cardsWithOrientation[2].displayName}</h4><div class="number">编号：${cardsWithOrientation[2].number}</div><div class="meaning">含义：${cardsWithOrientation[2].isReversed ? cardsWithOrientation[2].reversed.meaning : cardsWithOrientation[2].upright.meaning}</div><div class="message" style="margin-top:8px; font-style:italic;">传讯：${cardsWithOrientation[2].isReversed ? cardsWithOrientation[2].reversed.message : cardsWithOrientation[2].upright.message}</div>`;

                let combined = `<strong>三张牌结合起来看：</strong><br>`;
                let reversedCount = cardsWithOrientation.filter(c => c.isReversed).length;
                if (reversedCount >= 2) combined += '逆位牌较多，说明他现在内心有些矛盾和不安。';
                else combined += '整体来看，他的状态是积极的。';

                let hasEmotion = cardsWithOrientation.some(c => c.name.includes('恋人') || c.name.includes('圣杯') || c.name.includes('女皇') || c.name.includes('世界'));
                let hasConflict = cardsWithOrientation.some(c => c.name.includes('高塔') || c.name.includes('宝剑') || c.name.includes('死神') || c.name.includes('恶魔'));
                let hasThought = cardsWithOrientation.some(c => c.name.includes('隐士') || c.name.includes('女祭司') || c.name.includes('月亮'));

                let message = '';
                if (hasEmotion) message += '他内心充满情感，对你很在意。';
                if (hasConflict) message += '他可能正面临一些困扰或压力。';
                if (hasThought) message += '他最近思考很多，可能需要一些独处时间。';
                if (!hasEmotion && !hasConflict && !hasThought) message += '他的状态平稳，没有特别强烈的波动。';

                let cardMessages = cardsWithOrientation.map(c => c.isReversed ? c.reversed.message : c.upright.message);
                let combinedMessage = cardMessages.join('，') + '。';

                combined += `<br><br>他想对你说：<br>“${combinedMessage}”<br><br>`;
                combined += `<strong>结论：</strong><br>${message} 建议你多关注他的情绪变化，给彼此一些理解和空间。`;

                document.getElementById('summaryText').innerHTML = combined;

                document.getElementById('tarotLoading').style.display = 'none';
                document.getElementById('tarotResult').style.display = 'block';
                document.getElementById('statusResult').style.display = 'none';
                currentTarotResult = {
                    timestamp: new Date().toLocaleString(),
                    question: question,
                    cards: cardsWithOrientation,
                    message: combined,
                    status: ''
                };
                tarotHistory.unshift(currentTarotResult);
                saveTarotHistory();
            }, delay);
        };

        window.showTarotStatus = function() {
            if (!currentTarotResult) { alert('请先抽牌'); return; }
            let cards = currentTarotResult.cards;
            let status = '根据牌面，他内心深处的想法是：';
            if (cards.some(c => c.name.includes('恋人') || c.name.includes('圣杯'))) status += '他非常珍惜你们之间的关系，希望能更进一步。';
            else if (cards.some(c => c.name.includes('隐士') || c.name.includes('月亮'))) status += '他现在需要一些独处的时间来思考，但并不是想疏远你。';
            else if (cards.some(c => c.name.includes('高塔') || c.name.includes('死神'))) status += '他正经历一些转变，内心有些不安，需要你的支持。';
            else if (cards.some(c => c.name.includes('太阳') || c.name.includes('星星'))) status += '他对未来充满希望，希望能和你一起创造美好回忆。';
            else if (cards.some(c => c.name.includes('宝剑') || c.name.includes('恶魔'))) status += '他可能有些难以言说的烦恼，需要你主动关心。';
            else status += '他正在思考如何更好地与你相处，内心是真诚的。';
            status += ' 结合牌面，他希望你能够多一点耐心，多一份信任。';
            document.getElementById('statusResult').innerText = status;
            document.getElementById('statusResult').style.display = 'block';
            if (currentTarotResult) {
                currentTarotResult.status = status;
                let idx = tarotHistory.findIndex(h => h.timestamp === currentTarotResult.timestamp);
                if (idx !== -1) { tarotHistory[idx] = currentTarotResult; saveTarotHistory(); }
            }
        };

        window.showTarotHistory = function() {
            let historyList = document.getElementById('tarotHistoryList');
            historyList.innerHTML = '';
            if (tarotHistory.length === 0) historyList.innerHTML = '<div class="empty-tip">暂无历史记录</div>';
            else tarotHistory.forEach((item, index) => {
                let div = document.createElement('div');
                div.className = 'history-item';
                div.onclick = () => loadTarotHistoryItem(index);
                div.innerHTML = `<div class="time">${item.timestamp}</div><div class="question">问题：${item.question.substring(0,30)}${item.question.length>30?'...':''}</div><div class="cards">牌：${item.cards.map(c=>c.displayName).join('、')}</div>`;
                historyList.appendChild(div);
            });
            document.getElementById('tarotHistoryModal').style.display = 'flex';
        };
        window.closeTarotHistory = function() { document.getElementById('tarotHistoryModal').style.display = 'none'; };
        function loadTarotHistoryItem(index) {
            let item = tarotHistory[index];
            if (!item) return;
            document.getElementById('card1').innerHTML = `<h4>${item.cards[0].displayName}</h4><div class="number">编号：${item.cards[0].number}</div><div class="meaning">含义：${item.cards[0].isReversed ? item.cards[0].reversed.meaning : item.cards[0].upright.meaning}</div><div class="message" style="margin-top:8px; font-style:italic;">传讯：${item.cards[0].isReversed ? item.cards[0].reversed.message : item.cards[0].upright.message}</div>`;
            document.getElementById('card2').innerHTML = `<h4>${item.cards[1].displayName}</h4><div class="number">编号：${item.cards[1].number}</div><div class="meaning">含义：${item.cards[1].isReversed ? item.cards[1].reversed.meaning : item.cards[1].upright.meaning}</div><div class="message" style="margin-top:8px; font-style:italic;">传讯：${item.cards[1].isReversed ? item.cards[1].reversed.message : item.cards[1].upright.message}</div>`;
            document.getElementById('card3').innerHTML = `<h4>${item.cards[2].displayName}</h4><div class="number">编号：${item.cards[2].number}</div><div class="meaning">含义：${item.cards[2].isReversed ? item.cards[2].reversed.meaning : item.cards[2].upright.meaning}</div><div class="message" style="margin-top:8px; font-style:italic;">传讯：${item.cards[2].isReversed ? item.cards[2].reversed.message : item.cards[2].upright.message}</div>`;
            document.getElementById('summaryText').innerHTML = item.message;
            if (item.status) { document.getElementById('statusResult').innerText = item.status; document.getElementById('statusResult').style.display = 'block'; } else document.getElementById('statusResult').style.display = 'none';
            document.getElementById('tarotResult').style.display = 'block';
            document.getElementById('tarotLoading').style.display = 'none';
            closeTarotHistory();
            currentTarotResult = item;
        }

        // 新增缺失函数
        window.changeTheme = function(key, color) {
            if (key.endsWith('2')) key = key.slice(0, -1);
            themeData[key] = color;
            saveThemeData();
            initTheme();
            renderTheme();
        };
        window.setBgImage = function() {
            let ipt = document.createElement('input');
            ipt.type = 'file';
            ipt.accept = 'image/*';
            ipt.onchange = e => {
                let file = e.target.files[0];
                if (file) {
                    let reader = new FileReader();
                    reader.onload = res => {
                        themeData.bgImg = res.target.result;
                        saveThemeData();
                        if (currentTab === 'chat') applyChatPageBackground();
                        alert('背景图片已设置');
                    };
                    reader.readAsDataURL(file);
                }
            };
            ipt.click();
        };
        window.clearBg = function() {
            themeData.bgImg = '';
            saveThemeData();
            if (currentTab === 'chat') applyChatPageBackground();
            alert('背景已清除');
        };
        window.exportAllData = function() {
            let data = {
                user: userData,
                chat: chatData,
                theme: themeData,
                avatars: avatars,
                emojis: emojiData,
                letters: letterData,
                tarotHistory: tarotHistory,
                calendar: calendarData,
                incoming: incomingLetters
            };
            let json = JSON.stringify(data, null, 2);
            let blob = new Blob([json], { type: 'application/json' });
            let url = URL.createObjectURL(blob);
            let a = document.createElement('a');
            a.href = url;
            a.download = 'xinghe_backup_' + new Date().toISOString().slice(0,10) + '.json';
            a.click();
            URL.revokeObjectURL(url);
        };
        window.importAllData = function(event) {
            let file = event.target.files[0];
            if (!file) return;
            let reader = new FileReader();
            reader.onload = e => {
                try {
                    let data = JSON.parse(e.target.result);
                    if (data.user) { userData = data.user; localStorage.setItem('xingheUser', JSON.stringify(userData)); }
                    if (data.chat) { chatData = data.chat; saveChatDataDebounced(); }
                    if (data.theme) { themeData = data.theme; saveThemeData(); }
                    if (data.avatars) { avatars = data.avatars; saveAvatars(); }
                    if (data.emojis) { emojiData = data.emojis; saveEmojiData(); }
                    if (data.letters) { letterData = data.letters; saveLetterData(); }
                    if (data.tarotHistory) { tarotHistory = data.tarotHistory; saveTarotHistory(); }
                    if (data.calendar) { calendarData = data.calendar; saveCalendarData(); }
                    if (data.incoming) { incomingLetters = data.incoming; saveIncomingLetters(); }
                    alert('数据导入成功，即将刷新页面');
                    location.reload();
                } catch (err) { alert('导入失败：无效的JSON文件'); }
            };
            reader.readAsText(file);
        };
        window.clearStats = function() {
            if (!confirm('确定要清零所有统计次数吗？')) return;
            chatData.cardUse = {};
            chatData.chatTotal = 0;
            saveChatDataDebounced();
            if (currentTab === 'stats') renderStats();
            alert('统计次数已清零');
        };

        // 初始化
        document.addEventListener('DOMContentLoaded', function() {
            initData();
            const chatMain = document.getElementById('chatMain');
            if (chatMain) {
                chatMain.addEventListener('scroll', handleChatScroll);
                chatMain.addEventListener('contextmenu', function(e) {
                    e.preventDefault();
                    let target = e.target.closest('.msg-item');
                    if (!target) return;
                    let msgId = target.dataset.msgid;
                    let msg = chatData.msgMap[chatData.currentContact].find(m=>m.id===msgId);
                    if (!msg) return;
                    let isMe = msg.type==='me';
                    let now = Date.now();
                    let canRecall = isMe && (now - (msg.timestamp||now) < 120000);
                    let menu = document.getElementById('messageActionMenu');
                    let html = '';
                    if (canRecall) html += `<div class="message-action-item" onclick="recallMessage('${msgId}')">撤销</div>`;
                    if (isMe) html += `<div class="message-action-item delete" onclick="deleteMessage('${msgId}')">删除</div>`;
                    html += `<div class="message-action-item" onclick="quoteMessage('${msgId}')">引用</div>`;
                    menu.innerHTML = html;
                    menu.style.visibility = 'hidden';
                    menu.classList.add('active');
                    let menuWidth = menu.offsetWidth;
                    let menuHeight = menu.offsetHeight;
                    menu.classList.remove('active');
                    menu.style.visibility = '';
                    let x = e.pageX, y = e.pageY;
                    if (x + menuWidth > window.innerWidth) x = window.innerWidth - menuWidth - 5;
                    if (y + menuHeight > window.innerHeight) y = window.innerHeight - menuHeight - 5;
                    menu.style.left = x + 'px';
                    menu.style.top = y + 'px';
                    menu.classList.add('active');
                });
            }
            document.addEventListener('click', function(e) {
                let menu = document.getElementById('menuDropdown'); let menuBtn = document.querySelector('.menu-btn'); if (!menu.contains(e.target) && e.target !== menuBtn) menu.classList.remove('active');
                let contactDropdown = document.getElementById('contactDropdown'); let contactActionMenu = document.getElementById('contactActionMenu'); let contactSelector = document.querySelector('.contact-selector'); let contactMenuBtn = document.querySelector('.contact-menu-btn'); let emojiPanel = document.getElementById('emojiPanel'); let emojiBtn = document.querySelector('.emoji-btn'); let messageMenu = document.getElementById('messageActionMenu');
                if (!contactDropdown.contains(e.target) && e.target !== contactSelector) contactDropdown.classList.remove('active');
                if (!contactActionMenu.contains(e.target) && e.target !== contactMenuBtn) contactActionMenu.classList.remove('active');
                if (!emojiPanel.contains(e.target) && e.target !== emojiBtn) emojiPanel.classList.remove('active');
                if (!messageMenu.contains(e.target)) messageMenu.classList.remove('active');
            });
            document.getElementById('homeContainer').style.display = 'flex';
            document.getElementById('featurePages').style.display = 'none';
            autoLogin();
            if (themeData.mode === 'night') {
                document.body.classList.add('night-mode');
                document.getElementById('dayModeBtn').style.backgroundColor = '#40a9ff';
                document.getElementById('nightModeBtn').style.backgroundColor = '#1890ff';
                if (document.getElementById('dayModeBtn2')) {
                    document.getElementById('dayModeBtn2').style.backgroundColor = '#40a9ff';
                    document.getElementById('nightModeBtn2').style.backgroundColor = '#1890ff';
                }
            } else {
                document.getElementById('dayModeBtn').style.backgroundColor = '#1890ff';
                document.getElementById('nightModeBtn').style.backgroundColor = '#40a9ff';
                if (document.getElementById('dayModeBtn2')) {
                    document.getElementById('dayModeBtn2').style.backgroundColor = '#1890ff';
                    document.getElementById('nightModeBtn2').style.backgroundColor = '#40a9ff';
                }
            }
            renderHomeContactList();
        });
    </script>
</body>
</html>
