            emojiData = safeParse(localStorage.getItem(emojiKey), [ '😊','😂','😍','👍','❤️','🎉','😢','😡','😱','🤔', 'https://via.placeholder.com/30/FF6B6B/FFFFFF?text=😊', 'https://via.placeholder.com/30/4ECDC4/FFFFFF?text=😂' ]);
            letterData = safeParse(localStorage.getItem(letterKey), []);
